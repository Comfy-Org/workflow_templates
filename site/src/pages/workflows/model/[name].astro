---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubNavbar from '../../../components/hub/HubNavbar.astro';
import SiteFooter from '../../../components/hub/SiteFooter.astro';
import WorkflowGrid from '../../../components/hub/WorkflowGrid.vue';
import HreflangTags from '../../../components/HreflangTags.astro';
import BackButton from '../../../components/BackButton.astro';
import { getLocaleFromPath, localizeUrl } from '../../../i18n/utils';
import { t } from '../../../i18n/ui';
import { slugify } from '../../../lib/slugify';
import { SITE_ORIGIN, absoluteUrl } from '../../../config/site';
import { modelPath } from '../../../lib/routes';
import { badgeVariants } from '../../../components/ui/badge';
import creatorsData from '../../../../creators.json';
import { listWorkflowIndex } from '../../../lib/hub-api';

const creators = creatorsData as Record<string, { displayName: string; avatarUrl?: string }>;

interface TemplateEntry {
  name: string;
  shareId: string;
  title: string;
  tags: string[];
  logos: { provider: string | string[] }[];
  date: string;
  thumbnails: string[];
  username: string;
  models: string[];
  isApp: boolean;
}

export async function getStaticPaths() {
  // Try hub API first, fall back to content collection
  let allTemplates: TemplateEntry[];
  try {
    const entries = await listWorkflowIndex();
    allTemplates = entries.map((e) => ({
      name: e.name,
      shareId: e.shareId || '',
      title: e.title || e.name,
      tags: e.tags || [],
      logos: (e.logos || []) as { provider: string | string[] }[],
      date: e.date || '',
      thumbnails: [e.thumbnailUrl, e.thumbnailComparisonUrl].filter(Boolean) as string[],
      username: e.username || '',
      models: e.models || [],
      isApp: false,
    }));
  } catch {
    const collection = (await getCollection('templates')).filter((t) => !t.id.includes('/'));
    allTemplates = collection.map((t) => ({
      name: t.data.name,
      shareId: '',
      title: t.data.title || t.data.name,
      tags: t.data.tags || [],
      logos: t.data.logos || [],
      date: t.data.date || '',
      thumbnails: t.data.thumbnails || [],
      username: t.data.username || '',
      models: t.data.models || [],
      isApp: t.data.isApp || false,
    }));
  }

  const modelMap = new Map<string, TemplateEntry[]>();

  for (const template of allTemplates) {
    for (const model of template.models) {
      const normalized = slugify(model);
      if (!modelMap.has(normalized)) {
        modelMap.set(normalized, []);
      }
      modelMap.get(normalized)!.push(template);
    }
  }

  return Array.from(modelMap.entries()).map(([name, modelTemplates]) => {
    const originalName =
      modelTemplates[0]?.models?.find((m: string) => slugify(m) === name) || name;

    return {
      params: { name },
      props: {
        templates: modelTemplates,
        modelName: originalName,
      },
    };
  });
}

const { name } = Astro.params;
const { templates, modelName } = Astro.props;

const locale = getLocaleFromPath(Astro.url.pathname);
const basePath = modelPath(name!);

const title = `${modelName} ComfyUI Workflows - Free Templates`;
const description = `Browse ${templates.length} free ComfyUI workflow templates using ${modelName}. Ready-to-use AI generation workflows for image, video, and audio creation.`;

const canonicalUrl = absoluteUrl(localizeUrl(basePath, locale));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${modelName} ComfyUI Workflows`,
  description,
  url: canonicalUrl,
};

const breadcrumbStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_ORIGIN },
    {
      '@type': 'ListItem',
      position: 2,
      name: t('labels.models', locale),
      item: absoluteUrl(localizeUrl('/workflows/model/', locale)),
    },
    { '@type': 'ListItem', position: 3, name: modelName },
  ],
};

// Serialize templates for the Vue WorkflowGrid island
const serialized = templates.map((tmpl) => ({
  ...tmpl,
  usage: 0,
  creatorDisplayName:
    (tmpl.username && creators[tmpl.username]?.displayName) || 'ComfyUI',
  creatorAvatarUrl: (tmpl.username && creators[tmpl.username]?.avatarUrl) || '',
}));
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/og-default.png"
  structuredData={structuredData}
  theme="dark"
  hideDefaultFooter
>
  <HreflangTags slot="head" basePath={basePath} />
  <HubNavbar />
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-16 py-12">
    <!-- Back -->
    <nav class="mb-8">
      <BackButton locale={locale} />
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <span class={badgeVariants({ variant: 'hub-pill' })}>Model</span>
      <h1 class="text-3xl font-bold text-white mt-3">
        {modelName} Workflows
      </h1>
      <p class="text-hub-muted text-base mt-2">
        {templates.length} workflow{templates.length !== 1 ? 's' : ''}
      </p>
    </div>

    <!-- Interactive Grid -->
    <WorkflowGrid
      client:load
      templates={serialized}
      locale={locale}
      gridClass="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    />
  </div>

  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbStructuredData)}
  />

  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
