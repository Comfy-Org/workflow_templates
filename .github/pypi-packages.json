{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "PyPI project quota and per-file size thresholds. Packages are auto-discovered from packages/*/pyproject.toml and root pyproject.toml unless listed in extra_packages.",
  "project_quota_gb": 10,
  "warn_quota_percent": 80,
  "critical_quota_percent": 90,
  "fail_quota_percent": 95,
  "per_file_limit_mb": 100,
  "per_file_warn_mb": 85,
  "per_file_critical_mb": 95,
  "extra_packages": [],
  "comfyui_reference_check": {
    "enabled": true,
    "github_repo": "Comfy-Org/ComfyUI",
    "requirements_path": "requirements.txt",
    "local_repo_path": null,
    "fetch_requirements_via": "github_api",
    "default_branch": "master",
    "clone_depth": 500,
    "env_repo_path_var": "COMFYUI_REPO_PATH",
    "github_token_var": "GITHUB_TOKEN",
    "track_packages": [],
    "list_delete_candidates": true,
    "max_delete_candidates_listed": 40,
    "pins_cache_file": ".github/cache/comfyui-requirements-pins.json",
    "pins_cache_stale_days": 7
  }
}
