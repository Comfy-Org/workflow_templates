---
/** "Why ComfyUI" — sticky left heading with a list of reason rows on the right
 *  (title + supporting sentence), some flagged "Only on Comfy Cloud". */
import type { Locale } from '../../../i18n/config';
import type { WhyComfyReason } from '../../../lib/workflow-pages/schema';
import { t } from '../../../i18n/ui';
import { inner, sectionPad, eyebrow } from '../landing-styles';
import NodeBadge from '../../shared/NodeBadge.vue';

interface Props {
  locale: Locale;
  reasons: WhyComfyReason[];
}

const { locale, reasons } = Astro.props;

// "ONLY ON · Comfy · CLOUD" node badge, sized down for an inline row tag.
const cloudBadge = [
  { text: t('useCase.onlyOn', locale) },
  { logoSrc: '/icons/logo.svg', logoAlt: 'Comfy' },
  { text: t('useCase.cloud', locale) },
];
// Instance-scoped heading id so two renders on one page never collide.
const headingId = `why-heading-${crypto.randomUUID().slice(0, 8)}`;
---

<section aria-labelledby={headingId} class={`bg-page ${sectionPad}`}>
  <div class={`${inner} flex flex-col gap-12 lg:flex-row lg:gap-16`}>
    <!-- Sticky heading; offset clears the sticky navbar + search bar. -->
    <div class="lg:sticky lg:top-52 lg:h-fit lg:w-md lg:shrink-0">
      <p class={eyebrow}>{t('useCase.comparison', locale)}</p>
      <h2
        id={headingId}
        class="mt-3 font-display text-4xl font-light leading-[1.1] tracking-[-0.03em] text-content sm:text-5xl"
      >
        {t('useCase.whyComfy', locale)}
      </h2>
    </div>

    <!-- Reason rows -->
    <ul class="flex flex-1 flex-col">
      {
        reasons.map((reason) => (
          <li class="flex flex-col gap-3 border-b border-divider py-8 first:pt-0 last:border-b-0 lg:flex-row lg:gap-12 lg:py-9">
            <div class="flex flex-col items-start gap-3 lg:w-72 lg:shrink-0">
              <h3 class="font-display text-xl font-medium leading-[1.3] text-content lg:text-2xl">
                {reason.title}
              </h3>
              {reason.cloudOnly && (
                <NodeBadge
                  segments={cloudBadge}
                  sizeClass="h-7 sm:h-7"
                  segmentClass="px-2.5 py-0 sm:py-0 lg:py-0"
                  textClass="text-xs font-extrabold uppercase tracking-[0.04em] translate-y-0"
                  logoClass="h-3.5"
                />
              )}
            </div>
            <p class="flex-1 pt-0.5 font-display text-[0.9375rem] font-light leading-[1.65] text-content-muted lg:max-w-md">
              {reason.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
