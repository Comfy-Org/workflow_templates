---
/** "Why ComfyUI" — sticky left heading with a list of reason rows on the right
 *  (title + supporting sentence), some flagged "Only on Comfy Cloud". */
import type { Locale } from '../../../i18n/config';
import type { WhyComfyReason } from '../../../lib/workflow-pages/schema';
import { t } from '../../../i18n/ui';
import { inner, sectionPad, eyebrow } from '../landing-styles';

interface Props {
  locale: Locale;
  reasons: WhyComfyReason[];
}

const { locale, reasons } = Astro.props;

// "ONLY ON · Comfy · CLOUD" node-shaped badge, rendered inline in Astro (static
// markup, so no Vue island); segment glyphs come from /icons/node-*.svg.
const badgeText = 'flex items-center justify-center bg-brand px-2.5 text-page';
// `ppformula-text-center` nudges the PP Formula caps down to the optical middle
// of the node segment (the font sits high in its line box otherwise).
const badgeLabel = 'ppformula-text-center text-xs font-extrabold uppercase tracking-[0.04em]';
// Instance-scoped heading id so two renders on one page never collide.
const headingId = `why-heading-${crypto.randomUUID().slice(0, 8)}`;
---

<section aria-labelledby={headingId} class={`bg-page ${sectionPad}`}>
  <div class={`${inner} flex flex-col gap-12 lg:flex-row lg:gap-16`}>
    <!-- Sticky heading; offset clears the sticky navbar + search bar. -->
    <div class="lg:sticky lg:top-52 lg:h-fit lg:w-md lg:shrink-0">
      <p class={eyebrow}>{t('useCase.comparison', locale)}</p>
      <h2
        id={headingId}
        class="mt-3 font-display text-3xl font-light leading-[1.1] tracking-[-0.03em] text-content sm:text-4xl lg:text-5xl"
      >
        {t('useCase.whyComfy', locale)}
      </h2>
    </div>

    <!-- Reason rows -->
    <ul class="flex flex-1 flex-col">
      {
        reasons.map((reason) => (
          <li class="flex flex-col gap-3 border-b border-divider py-8 first:pt-0 last:border-b-0 lg:flex-row lg:gap-12 lg:py-9">
            <div class="flex flex-col items-start gap-3 lg:w-72 lg:shrink-0">
              <h3 class="font-display text-xl font-medium leading-[1.3] text-content lg:text-2xl">
                {reason.title}
              </h3>
              {reason.cloudOnly && (
                <div class="flex h-7 items-stretch font-semibold select-none">
                  <img
                    src="/icons/node-left.svg"
                    alt=""
                    class="-mx-px h-full w-auto self-stretch"
                    aria-hidden="true"
                  />
                  <span class={badgeText}>
                    <span class={badgeLabel}>{t('useCase.onlyOn', locale)}</span>
                  </span>
                  <img
                    src="/icons/node-union.svg"
                    alt=""
                    class="-mx-px h-full w-auto self-stretch"
                    aria-hidden="true"
                  />
                  <span class={badgeText}>
                    <img src="/icons/logo.svg" alt="Comfy" class="h-3.5 brightness-0" />
                  </span>
                  <img
                    src="/icons/node-union.svg"
                    alt=""
                    class="-mx-px h-full w-auto self-stretch"
                    aria-hidden="true"
                  />
                  <span class={badgeText}>
                    <span class={badgeLabel}>{t('useCase.cloud', locale)}</span>
                  </span>
                  <img
                    src="/icons/node-right.svg"
                    alt=""
                    class="-mx-px h-full w-auto self-stretch"
                    aria-hidden="true"
                  />
                </div>
              )}
            </div>
            <p class="flex-1 pt-0.5 font-display text-[0.9375rem] font-light leading-[1.65] text-content-muted lg:max-w-md">
              {reason.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
