---
/**
 * Localized model page (on-demand rendered)
 * Serves pages like /zh/workflows/model/flux/, /ja/workflows/model/sdxl/, etc.
 */
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import HubNavbar from '../../../../components/hub/HubNavbar.astro';
import SiteFooter from '../../../../components/hub/SiteFooter.astro';
import WorkflowGrid from '../../../../components/hub/WorkflowGrid.vue';
import BackButton from '../../../../components/BackButton.astro';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../../i18n/config';
import { localizeUrl } from '../../../../i18n/utils';
import { t } from '../../../../i18n/ui';
import { absoluteUrl } from '../../../../config/site';
import { modelPath, modelsIndexPath } from '../../../../lib/routes';
import { deriveModelGroups } from '../../../../lib/workflow-pages/model-groups';
import { loadModelContent } from '../../../../lib/workflow-pages/content-loaders';
import { buildModelPageMeta, isModelPageIndexable } from '../../../../lib/workflow-pages/seo-page';
import { badgeVariants } from '../../../../components/ui/badge';
import { loadSerializedTemplates } from '../../../../lib/hub-api';
import { buildToolbarLabels } from '../../../../lib/toolbar';
import { buildTemplateItemListEntries } from '../../../../lib/workflow-pages/item-list';
import {
  buildCollectionPageJsonLd,
  buildWorkflowBreadcrumb,
  serializeJsonLdForScript,
} from '../../../../lib/structured-data';

const buildGroups = async () =>
  deriveModelGroups(await loadSerializedTemplates(() => getCollection('templates')));
let groupsCache: ReturnType<typeof buildGroups> | null = null;
const loadModelGroups = () => (groupsCache ??= buildGroups());

const { locale, name } = Astro.params;

// Validate locale
if (!locale || !LOCALES.includes(locale as Locale) || locale === DEFAULT_LOCALE) {
  return Astro.redirect(`/workflows/model/${name || ''}/`);
}

const typedLocale = locale as Locale;

// Resolve the model family via the same grouping the English page uses, so both
// routes agree on canonical slugs, variant redirects, and display label — the
// hreflang cluster between them is only reciprocal if the slugs resolve identically.
const groups = await loadModelGroups();
const family =
  groups.find((group) => group.slug === name) ??
  groups.find((group) => group.redirectFrom.includes(name!));

if (!family) {
  return Astro.redirect(`/${locale}/workflows/`);
}

// A variant slug 301s to its family's canonical URL, matching the English route.
if (family.slug !== name) {
  return Astro.redirect(localizeUrl(modelPath(family.slug), typedLocale), 301);
}

const matchingTemplates = family.templates;
const basePath = modelPath(family.slug);
const canonicalUrl = absoluteUrl(localizeUrl(basePath, typedLocale));

// Localized pages carry no editorial copy of their own, but title/meta/noindex
// resolve through the same helper as the English route so the hreflang cluster
// stays consistent.
const content = await loadModelContent(family.slug);
const { h1, title, description } = buildModelPageMeta({
  group: family,
  content,
  locale: typedLocale,
  templateCount: matchingTemplates.length,
});
const noindex = !isModelPageIndexable(family, matchingTemplates.length, content);

const countLabel =
  matchingTemplates.length === 1
    ? t('template.countOne', typedLocale)
    : t('template.count', typedLocale);

const structuredData = buildCollectionPageJsonLd({
  name: h1,
  description,
  url: canonicalUrl,
  inLanguage: typedLocale,
  items: noindex ? undefined : buildTemplateItemListEntries(matchingTemplates, typedLocale),
});

const breadcrumbStructuredData = buildWorkflowBreadcrumb(typedLocale, { name: h1 }, [
  {
    name: t('breadcrumb.workflows', typedLocale),
    item: absoluteUrl(localizeUrl('/workflows/', typedLocale)),
  },
  { name: t('labels.models', typedLocale), item: absoluteUrl(modelsIndexPath(typedLocale)) },
]);

// matchingTemplates are already SerializedTemplate[] with profile data
const serialized = matchingTemplates;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/brand/og-default-v2.png"
  structuredData={structuredData}
  locale={typedLocale}
  hreflangBasePath={basePath}
  noindex={noindex}
  theme="dark"
  hideDefaultFooter
>
  <HubNavbar />
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-16 py-12">
    <!-- Back -->
    <nav class="mb-8">
      <BackButton locale={typedLocale} />
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <span class={badgeVariants({ variant: 'hub-pill' })}>{t('labels.models', typedLocale)}</span>
      <h1 class="text-3xl font-bold text-content mt-3">
        {h1}
      </h1>
      <p class="text-content-muted text-base mt-2">
        {matchingTemplates.length}
        {countLabel}
      </p>
    </div>

    <!-- Interactive Grid -->
    <WorkflowGrid
      client:load
      templates={serialized}
      locale={typedLocale}
      toolbarLabels={buildToolbarLabels(typedLocale)}
      gridClass="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
    />
  </div>

  <script
    is:inline
    type="application/ld+json"
    set:html={serializeJsonLdForScript(breadcrumbStructuredData)}
  />

  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
