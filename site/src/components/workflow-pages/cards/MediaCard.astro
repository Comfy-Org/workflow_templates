---
/** Simple media card: image on top (with optional model badges), then eyebrow,
 *  title, and description. A "Try workflow" CTA sits to the right of the copy and,
 *  with the image, links to the template. Used for the "What is X" intro cards. */
import type { CardImage } from '../../../lib/workflow-pages/card-images';
import type { ModelBadge } from '../../../lib/model-logos';
import Thumbnail from '../Thumbnail.astro';
import ModelBadges from '../ModelBadges.astro';
import { ButtonPill } from '../../ui/button-pill';

interface Props {
  eyebrow?: string;
  title?: string;
  text: string;
  image?: CardImage | null;
  logos?: ModelBadge[];
  cta?: { label: string; href: string } | null;
}

const { eyebrow, title, text, image, logos = [], cta } = Astro.props;

const ImageTag = cta?.href ? 'a' : 'div';
const imageLinkProps = cta?.href
  ? { href: cta.href, target: '_blank', rel: 'noopener noreferrer', 'aria-label': cta.label }
  : {};
---

<article
  class="group/pill-trigger group flex h-full flex-col rounded-4xl bg-hub-surface p-2 transition-colors duration-300 hover:bg-hub-surface-hover"
>
  {
    image && (
      <ImageTag
        {...imageLinkProps}
        class="relative block aspect-video w-full overflow-hidden rounded-3xl"
      >
        <Thumbnail
          src={image.src}
          alt={image.alt}
          class="size-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
        />
        <ModelBadges logos={logos} class="absolute top-3 right-3 z-10" />
      </ImageTag>
    )
  }
  <div class="flex flex-1 flex-col p-5 lg:p-6">
    {
      eyebrow && (
        <p class="font-display text-xs font-extrabold uppercase tracking-[0.05em] text-brand">
          {eyebrow}
        </p>
      )
    }
    <div class="mt-2.5 flex items-start justify-between gap-4">
      {
        title && (
          <h3 class="font-display text-xl font-medium leading-[1.3] text-content sm:text-2xl">
            {title}
          </h3>
        )
      }
      {
        cta && (
          <ButtonPill
            as="a"
            href={cta.href}
            target="_blank"
            rel="noopener noreferrer"
            variant="solid"
            mode="icon"
            aria-label={cta.label}
            class="shrink-0"
          />
        )
      }
    </div>
    <p class="mt-3 font-display text-[0.9375rem] font-light leading-[1.6] text-content-secondary">
      {text}
    </p>
  </div>
</article>
