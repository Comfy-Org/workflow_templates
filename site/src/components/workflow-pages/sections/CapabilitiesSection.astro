---
import type { Locale } from '../../../i18n/config';
import type { CardImage } from '../../../lib/workflow-pages/card-images';
import { t } from '../../../i18n/ui';
import { inner, sectionPad } from '../landing-styles';
import SectionHeader from '../SectionHeader.astro';
import SplitCard from '../cards/SplitCard.astro';
import ShowMore from '../ShowMore.vue';

export interface CapabilityCard {
  title?: string;
  text: string;
  image?: CardImage | null;
  logo?: string | null;
  cta?: { label: string; href: string } | null;
}

interface Props {
  locale: Locale;
  eyebrowLabel: string;
  headingLabel: string;
  cards: CapabilityCard[];
  summary?: string;
}

const { locale, eyebrowLabel, headingLabel, cards, summary } = Astro.props;

// Show the first three rows; reveal the rest behind a "Show more" toggle.
const VISIBLE = 3;
const visibleCards = cards.slice(0, VISIBLE);
const hiddenCards = cards.slice(VISIBLE);
// Instance-scoped heading id so two renders on one page never collide.
const headingId = `capabilities-heading-${crypto.randomUUID().slice(0, 8)}`;
---

<section aria-labelledby={headingId} class={`bg-page ${sectionPad}`}>
  <div class={inner}>
    <SectionHeader
      id={headingId}
      eyebrowLabel={eyebrowLabel}
      headingLabel={headingLabel}
      summary={summary}
    />
    <div class="flex flex-col gap-6 lg:gap-8">
      {
        visibleCards.map((card, i) => (
          <SplitCard
            index={i}
            title={card.title}
            text={card.text}
            image={card.image}
            logo={card.logo}
            cta={card.cta}
          />
        ))
      }
    </div>

    {
      hiddenCards.length > 0 && (
        <ShowMore
          client:visible
          moreLabel={t('useCase.showMoreCapabilities', locale)}
          lessLabel={t('useCase.showLessCapabilities', locale)}
        >
          <div class="flex flex-col gap-6 lg:gap-8">
            {hiddenCards.map((card, i) => (
              <SplitCard
                index={VISIBLE + i}
                title={card.title}
                text={card.text}
                image={card.image}
                logo={card.logo}
                cta={card.cta}
              />
            ))}
          </div>
        </ShowMore>
      )
    }
  </div>
</section>
