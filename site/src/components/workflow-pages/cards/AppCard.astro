---
/** Application card: an image with the title overlaid top-left (over a scrim)
 *  and the caption below. The image and a "Try workflow" CTA link to the
 *  template; the card body itself is not a link (so the CTA stays clickable). */
import type { CardImage } from '../../../lib/workflow-pages/card-images';
import type { ModelBadge } from '../../../lib/model-logos';
import Thumbnail from '../Thumbnail.astro';
import ModelBadges from '../ModelBadges.astro';
import { ButtonPill } from '../../ui/button-pill';

interface Props {
  title: string;
  subtitle?: string;
  image?: CardImage | null;
  logos?: ModelBadge[];
  href?: string | null;
  ctaLabel?: string;
}

const { title, subtitle, image, logos = [], href, ctaLabel } = Astro.props;
const ImageTag = href ? 'a' : 'div';
---

<article
  class="group/pill-trigger group flex flex-col gap-4 rounded-4xl bg-hub-surface p-2 transition-colors duration-300 hover:bg-hub-surface-hover"
>
  <ImageTag
    {...href ? { href, target: '_blank', rel: 'noopener noreferrer', 'aria-label': title } : {}}
    class="relative block aspect-video w-full overflow-hidden rounded-3xl"
  >
    <Thumbnail
      src={image?.src}
      alt={image?.alt ?? title}
      class="absolute inset-0 size-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
    />
    <!-- Top scrim keeps the overlaid title legible over any image. -->
    <div
      class="absolute inset-x-0 top-0 h-1/2 bg-linear-to-b from-black/45 to-transparent"
      aria-hidden="true"
    >
    </div>

    <h3
      class="absolute left-5 right-16 top-5 font-display text-lg font-medium leading-tight text-white lg:text-2xl"
    >
      {title}
    </h3>

    <ModelBadges logos={logos} class="absolute right-4 top-4 z-10" />
  </ImageTag>

  <!-- Caption on the left, CTA pinned bottom-right (closed pill, no reveal). -->
  <div class="flex items-end justify-between gap-4 px-4 pb-2">
    {
      subtitle && (
        <p class="font-display text-sm font-light leading-snug text-content-secondary">
          {subtitle}
        </p>
      )
    }
    {
      href && ctaLabel && (
        <ButtonPill
          as="a"
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          variant="solid"
          mode="icon"
          aria-label={ctaLabel}
          class="shrink-0"
        />
      )
    }
  </div>
</article>
