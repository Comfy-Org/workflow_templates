---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubNavbar from '../../../components/hub/HubNavbar.astro';
import SiteFooter from '../../../components/hub/SiteFooter.astro';
import WorkflowGrid from '../../../components/hub/WorkflowGrid.vue';
import Breadcrumbs from '../../../components/template-detail/Breadcrumbs.astro';
import SeoPageBody from '../../../components/seo/SeoPageBody.astro';
import HeroCollage from '../../../components/seo/HeroCollage.astro';
import { inner, eyebrow, heading } from '../../../components/seo/seo-styles';
import { ICON_PATHS } from '../../../components/seo/seo-icons';
import { getLocaleFromPath, localizeUrl } from '../../../i18n/utils';
import { t } from '../../../i18n/ui';
import { SITE_ORIGIN, absoluteUrl } from '../../../config/site';
import { modelPath, useCasePath } from '../../../lib/routes';
import { getCloudCtaUrl, getCloudLandingUrl } from '../../../lib/urls';
import { buildToolbarLabels } from '../../../lib/toolbar';
import { badgeVariants } from '../../../components/ui/badge';
import { loadSerializedTemplates } from '../../../lib/hub-api';
import { deriveModelGroups, type ModelGroup } from '../../../lib/seo/model-groups';
import { loadModelContent } from '../../../lib/seo/content-loaders';
import { useCasesFeaturingModel } from '../../../lib/seo/use-case-resolver';
import { type SeoPageDef } from '../../../config/seo-pages';
import { isIndexable } from '../../../lib/seo/governance';
import {
  buildCollectionPageJsonLd,
  buildBreadcrumbJsonLd,
  buildFaqJsonLd,
  serializeJsonLdForScript,
} from '../../../lib/structured-data';

export async function getStaticPaths() {
  const catalog = await loadSerializedTemplates(() => getCollection('templates'));
  const groups = deriveModelGroups(catalog);
  const paths: {
    params: { name: string };
    props: { group: ModelGroup; relatedUseCases: SeoPageDef[]; redirectTo?: string };
  }[] = [];

  for (const group of groups) {
    const relatedUseCases = useCasesFeaturingModel(group.slug, catalog);
    paths.push({ params: { name: group.slug }, props: { group, relatedUseCases } });
    for (const variant of group.redirectFrom) {
      paths.push({
        params: { name: variant },
        props: { group, relatedUseCases, redirectTo: group.slug },
      });
    }
  }
  return paths;
}

const {
  group,
  relatedUseCases: relatedUseCaseDefs,
  redirectTo,
} = Astro.props as {
  group: ModelGroup;
  relatedUseCases: SeoPageDef[];
  redirectTo?: string;
};
const locale = getLocaleFromPath(Astro.url.pathname);

if (redirectTo) {
  return Astro.redirect(localizeUrl(modelPath(redirectTo), locale), 301);
}

const { label, templates, keywords } = group;
const content = await loadModelContent(group.slug);
const basePath = modelPath(group.slug);
const canonicalUrl = absoluteUrl(localizeUrl(basePath, locale));

const isRich = group.qualifies && !!content && !content.qualityFailed;
const h1 = `${label} ComfyUI Workflows`;
const title = content
  ? `${label} ComfyUI Workflows — Ready-to-Run Templates`
  : `${label} Workflows`;
const description =
  content?.metaDescription ||
  `Browse ${templates.length} ready-to-use ComfyUI workflow templates using ${label}. AI generation workflows that run on Comfy Cloud with no setup.`;
const subheading =
  content?.subheading ||
  `Ready-to-run ComfyUI workflows built on ${label}, fully editable and runnable on Comfy Cloud with no setup.`;

const noindex =
  !isRich ||
  !isIndexable({ clusterSize: templates.length, humanEdited: true, qualityPassed: true });

const leadShareId = templates.find((template) => template.shareId)?.shareId;
const heroCtaUrl = leadShareId
  ? getCloudCtaUrl(leadShareId, `model_${group.slug}_hero`)
  : getCloudLandingUrl(`model_${group.slug}_hero`);
const footerCtaUrl = leadShareId
  ? getCloudCtaUrl(leadShareId, `model_${group.slug}_footer`)
  : getCloudLandingUrl(`model_${group.slug}_footer`);

const modelsUrl = absoluteUrl(localizeUrl('/workflows/model/', locale));
const breadcrumbTrail = [
  { label: t('labels.models', locale), href: localizeUrl('/workflows/model/', locale) },
];

const structuredData = buildCollectionPageJsonLd({ name: h1, description, url: canonicalUrl });
const breadcrumbStructuredData = buildBreadcrumbJsonLd([
  { name: t('breadcrumb.home', locale), item: SITE_ORIGIN },
  {
    name: t('breadcrumb.workflows', locale),
    item: absoluteUrl(localizeUrl('/workflows/', locale)),
  },
  { name: t('labels.models', locale), item: modelsUrl },
  { name: h1 },
]);
const faqStructuredData = isRich ? buildFaqJsonLd(content!.faqItems) : null;

// Use-cases featuring this model family, derived from grid overlap.
const relatedUseCases = isRich
  ? relatedUseCaseDefs.map((def) => ({
      label: def.h1,
      href: localizeUrl(useCasePath(def.slug), locale),
    }))
  : [];

const topTags = [...new Set(templates.flatMap((template) => template.tags))].slice(0, 3);
const atAGlance = isRich
  ? [
      { label: t('useCase.glanceWorkflows', locale), value: String(templates.length) },
      ...(topTags.length ? [{ label: t('labels.tags', locale), value: topTags.join(', ') }] : []),
      { label: t('useCase.glanceSetup', locale), value: t('useCase.glanceNoSetup', locale) },
    ]
  : undefined;

const hasHeroCollage = templates.some((template) => template.thumbnails?.length);

const pillClass = badgeVariants({ variant: 'hub-pill' });
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/workflows/og-default.png"
  structuredData={structuredData}
  locale={locale}
  hreflangBasePath={basePath}
  theme="dark"
  noindex={noindex}
  hideDefaultFooter
>
  <HubNavbar />

  <article class="bg-page min-h-screen text-content scroll-smooth hyphens-none wrap-normal">
    <header class="bg-page pt-4 lg:pt-6">
      <div class={inner}>
        <Breadcrumbs locale={locale} title={h1} trail={breadcrumbTrail} />
      </div>
      <div
        class:list={[
          inner,
          'pt-12 pb-16 lg:pt-16 lg:pb-24',
          hasHeroCollage
            ? 'grid items-center gap-12 lg:grid-cols-2 lg:gap-16'
            : 'flex flex-col items-center text-center',
        ]}
      >
        <div
          class:list={['flex flex-col', hasHeroCollage ? 'items-start text-left' : 'items-center']}
        >
          <span class={pillClass}>{t('labels.models', locale)}</span>
          <h1
            class="mt-4 max-w-4xl text-balance font-display text-4xl font-bold leading-[1.1] tracking-tight text-content-bright sm:text-5xl lg:text-6xl"
          >
            {h1}
          </h1>
          <p
            class="font-body mt-6 max-w-xl text-pretty text-base leading-relaxed text-content-secondary sm:text-lg"
          >
            {subheading}
          </p>

          <div
            class:list={[
              'mt-9 flex flex-wrap items-center gap-3',
              !hasHeroCollage && 'justify-center',
            ]}
          >
            <a
              href={heroCtaUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-brand px-7 py-3 text-sm font-bold text-page transition-opacity hover:opacity-90"
            >
              {t('cta.tryCloud', locale)}
            </a>
            <a
              href="#workflows"
              class="inline-flex items-center justify-center rounded-full border border-divider px-7 py-3 text-sm font-medium text-content transition-colors hover:border-border-strong"
            >
              {t('template.viewAllWorkflows', locale)}
            </a>
          </div>

          <ul
            class:list={[
              'font-body mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-content-muted',
              !hasHeroCollage && 'justify-center',
            ]}
          >
            <li class="flex items-center gap-1.5">
              <svg class="size-4 text-brand" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d={ICON_PATHS.layers}
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              {templates.length}
              {t('template.count', locale)}
            </li>
            <li class="flex items-center gap-1.5">
              <svg class="size-4 text-brand" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d={ICON_PATHS.zap}
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              {t('useCase.noSetupShort', locale)}
            </li>
            <li class="flex items-center gap-1.5">
              <svg class="size-4 text-brand" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d={ICON_PATHS.badge}
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              {t('useCase.fullyEditable', locale)}
            </li>
          </ul>
        </div>

        {hasHeroCollage && <HeroCollage templates={templates} class="w-full max-lg:hidden" />}
      </div>
    </header>

    <section
      id="workflows"
      class="scroll-mt-8 border-t border-divider bg-hub-surface py-20 lg:py-28"
    >
      <div class={inner}>
        <p class={eyebrow}>{t('useCase.theWorkflows', locale)}</p>
        <h2 class={`${heading} mb-8 lg:mb-10`}>
          {templates.length}
          {h1}
        </h2>
        <WorkflowGrid
          client:load
          templates={templates}
          locale={locale}
          toolbarLabels={buildToolbarLabels(locale)}
          gridClass="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
        />
      </div>
    </section>

    {
      isRich && (
        <SeoPageBody
          locale={locale}
          kind="model"
          keyword={keywords.primary}
          intro={content!.extendedDescription}
          atAGlance={atAGlance}
          modelSpec={content!.modelSpec}
          specName={label}
          howToUse={content!.howToUse}
          comparison={content!.comparison}
          suggestedUseCases={content!.suggestedUseCases}
          faqItems={content!.faqItems}
        />
      )
    }

    {
      relatedUseCases.length > 0 && (
        <section aria-labelledby="related-heading" class="bg-page py-20 lg:py-24">
          <div class={`${inner} flex flex-col gap-8`}>
            <div>
              <p class={eyebrow}>{t('useCase.explore', locale)}</p>
              <h2 id="related-heading" class={heading}>
                {t('useCase.relatedUseCases', locale)}
              </h2>
            </div>
            <ul class="flex flex-wrap gap-3">
              {relatedUseCases.map((uc) => (
                <li>
                  <a
                    href={uc.href}
                    class="group inline-flex items-center gap-2 rounded-full border border-divider bg-hub-surface py-2 pl-4 pr-3.5 font-body text-sm text-content transition-colors hover:border-brand/40 hover:bg-hub-surface-hover"
                  >
                    {uc.label}
                    <svg
                      class="size-3.5 shrink-0 text-content-muted transition-transform group-hover:translate-x-0.5 group-hover:text-brand"
                      viewBox="0 0 24 24"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M5 12h14M12 5l7 7-7 7"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )
    }

    {
      isRich && (
        <section class="border-t border-divider bg-hub-surface py-20 lg:py-28">
          <div class={`${inner} flex flex-col items-center text-center`}>
            <h2 class="font-display text-3xl lg:text-4xl font-semibold tracking-tight text-content-bright">
              {t('template.ready', locale)}
            </h2>
            <p class="font-body mt-3 max-w-xl text-base text-content-secondary">
              {t('template.startNow', locale)}
            </p>
            <a
              href={footerCtaUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center justify-center rounded-full bg-brand px-8 py-3.5 text-sm font-bold text-page transition-opacity hover:opacity-90"
            >
              {t('cta.tryCloud', locale)}
            </a>
          </div>
        </section>
      )
    }
  </article>

  <script
    is:inline
    type="application/ld+json"
    set:html={serializeJsonLdForScript(breadcrumbStructuredData)}
  />
  {
    faqStructuredData && (
      <script
        is:inline
        type="application/ld+json"
        set:html={serializeJsonLdForScript(faqStructuredData)}
      />
    )
  }

  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
