---
import ThumbnailDisplay from '../ThumbnailDisplay.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import SidebarSection from './SidebarSection.astro';
import CollapsibleBadgeList from './CollapsibleBadgeList.vue';
import FaqAccordion from './FaqAccordion.vue';
import ExpandableText from './ExpandableText.vue';
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/ui';
import { localizeUrl } from '../../i18n/utils';
import { getCloudCtaUrl, getWorkflowDownloadUrl } from '../../lib/urls';
import { slugify } from '../../lib/slugify';
import { tagSlug, tagDisplayName } from '../../lib/tag-aliases';
import { getProfileCache, type MediaType, type ThumbnailVariant } from '../../lib/hub-api';
import { featureFlags } from '../../config/featureFlags';
import { buttonVariants } from '../ui/button';
import { cn } from '../../lib/utils';

interface Props {
  template: {
    data: {
      name: string;
      shareId?: string;
      title?: string;
      description: string;
      extendedDescription?: string;
      mediaType: MediaType;
      mediaSubtype?: string;
      thumbnailVariant?: ThumbnailVariant;
      thumbnails?: string[];
      detailImages?: string[];
      includeOnDistributions?: string[];
      tags?: string[];
      models?: string[];
      username?: string;
      date?: string;
      faqItems?: { question: string; answer: string }[];
    };
  };
  locale: Locale;
}

const { template, locale } = Astro.props;
const { data } = template;

const profiles = await getProfileCache();
const profile = data.username ? profiles.get(data.username) : null;
const authorName = profile?.display_name || data.username || 'ComfyUI';
const authorAvatarUrl = profile?.avatar_url || null;
const authorProfileUrl = data.username
  ? localizeUrl(`/workflows/${slugify(data.username)}/`, locale)
  : null;
const thumbnails = data.detailImages?.length ? data.detailImages : data.thumbnails || [];
const showCloudCta = !data.includeOnDistributions || data.includeOnDistributions.includes('cloud');
const cloudTemplateId = data.shareId || data.name;
const downloadUrl = data.shareId
  ? getWorkflowDownloadUrl(data.shareId, data.name)
  : `/workflows/${data.name}.json`;

const mediaTypeLabels: Record<string, string> = {
  image: t('category.image', locale),
  video: t('category.video', locale),
  audio: t('category.audio', locale),
  '3d': t('category.3d', locale),
};

function formatRelativeDate(dateStr: string): string {
  const now = new Date();
  const date = new Date(dateStr);
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return '1 day ago';
  if (diffDays < 30) return `${diffDays} days ago`;
  const diffMonths = Math.floor(diffDays / 30);
  if (diffMonths === 1) return '1 month ago';
  if (diffMonths < 12) return `${diffMonths} months ago`;
  const diffYears = Math.floor(diffMonths / 12);
  if (diffYears === 1) return '1 year ago';
  return `${diffYears} years ago`;
}
---

<article
  class="template-detail-page bg-page min-h-screen text-content scroll-smooth"
  data-template={data.name}
  data-media-type={data.mediaType}
  data-author={data.username || ''}
>
  <div class="max-w-400 mx-auto px-6 lg:px-[clamp(0.25rem,4vw,5rem)] pt-4 lg:pt-8 pb-32">
    <Breadcrumbs locale={locale} title={data.title || data.name} class="mb-6 lg:mb-8" />

    <div
      class="flex flex-col lg:grid lg:grid-cols-[22.5rem_1fr] gap-8 lg:gap-16 w-full lg:items-start"
    >
      <aside
        class="order-2 lg:order-1 lg:col-start-1 lg:row-start-1 lg:row-span-2 w-full lg:self-start lg:sticky lg:top-48"
      >
        <div class="flex flex-col gap-6">
          <SidebarSection title="Workflow">
            <div class="min-w-0">
              <h1 class="text-base font-semibold text-content">{data.title || data.name}</h1>
              {
                data.description && (
                  <div class="mt-2">
                    <ExpandableText
                      client:load
                      paragraphs={[data.description]}
                      textClass="text-sm text-hub-muted"
                      collapsedMax={60}
                      moreLabel={t('template.readMore', locale)}
                      lessLabel={t('template.readLess', locale)}
                    />
                  </div>
                )
              }
            </div>
          </SidebarSection>

          <div class="flex flex-col gap-3">
            {
              showCloudCta && (
                <a
                  href={getCloudCtaUrl(cloudTemplateId, 'hero')}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={cn(
                    buttonVariants({ variant: 'brand-solid' }),
                    'run-cloud-btn flex h-auto flex-col py-2 transition-opacity'
                  )}
                  data-template={data.name}
                  data-author={data.username || ''}
                  data-location="hero"
                >
                  <span class="font-bold">{t('cta.tryCloud', locale)}</span>
                  {featureFlags.cloudFreeTier && (
                    <span class="font-normal text-xs">{t('cta.tryCloudSubline', locale)}</span>
                  )}
                </a>
              )
            }
            <a
              href={downloadUrl}
              download
              class={cn(
                buttonVariants({ variant: 'pill-outline' }),
                'download-json-btn h-10 rounded-2xl transition-colors'
              )}
              data-template={data.name}
              data-author={data.username || ''}
            >
              {t('cta.downloadJson', locale)}
            </a>
          </div>

          {
            data.tags && data.tags.length > 0 && (
              <SidebarSection title={t('labels.categories', locale)}>
                <CollapsibleBadgeList
                  client:load
                  items={[
                    {
                      label: mediaTypeLabels[data.mediaType],
                      href: localizeUrl(`/workflows/category/${data.mediaType}/`, locale),
                    },
                    ...data.tags.map((tag: string) => ({
                      label: tagDisplayName(tag),
                      href: localizeUrl(`/workflows/tag/${tagSlug(tag)}/`, locale),
                    })),
                  ]}
                />
              </SidebarSection>
            )
          }

          {
            data.models && data.models.length > 0 && (
              <SidebarSection title={t('labels.models', locale)}>
                <CollapsibleBadgeList
                  client:load
                  items={data.models.map((model: string) => ({
                    label: model,
                    href: localizeUrl(`/workflows/model/${slugify(model)}/`, locale),
                  }))}
                />
              </SidebarSection>
            )
          }

          <SidebarSection title={t('labels.createdBy', locale)}>
            <div class="flex items-center gap-3">
              <div class="size-8 shrink-0 rounded-full overflow-hidden">
                {
                  authorAvatarUrl ? (
                    <img
                      src={authorAvatarUrl}
                      alt={authorName}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full rounded-full bg-brand flex items-center justify-center text-xs font-bold text-page">
                      {authorName.charAt(0).toUpperCase()}
                    </div>
                  )
                }
              </div>
              <div class="flex flex-col">
                {
                  authorProfileUrl ? (
                    <a
                      href={authorProfileUrl}
                      class="font-semibold text-base text-content hover:opacity-80 transition-opacity"
                      data-astro-prefetch
                    >
                      {authorName}
                    </a>
                  ) : (
                    <span class="font-semibold text-base text-content">{authorName}</span>
                  )
                }
                {
                  data.date && (
                    <span class="text-xs text-content-secondary">
                      {formatRelativeDate(data.date)}
                    </span>
                  )
                }
              </div>
            </div>
          </SidebarSection>
        </div>
      </aside>

      {
        thumbnails.length > 0 && (
          <div class="order-1 lg:order-2 lg:col-start-2 media-frame relative aspect-4/3 w-full max-w-full overflow-hidden rounded-lg">
            <ThumbnailDisplay
              thumbnails={thumbnails}
              title={data.title || data.name}
              variant={data.thumbnailVariant}
              mediaSubtype={data.mediaSubtype}
              class="absolute inset-0 h-full w-full"
              loading="eager"
              fetchpriority="high"
              sizes="(min-width: 1024px) 65vw, 100vw"
            />
          </div>
        )
      }

      {
        data.extendedDescription && (
          <section id="description" class="order-3 min-w-0 scroll-mt-8 lg:col-start-2">
            <ExpandableText
              client:load
              paragraphs={data.extendedDescription
                .split('\n\n')
                .map((p: string) => p.trim())
                .filter(Boolean)}
              moreLabel={t('template.readMore', locale)}
              lessLabel={t('template.readLess', locale)}
            />
          </section>
        )
      }
    </div>

    {/* FAQ (renders nothing when there are no items) */}
    {
      data.faqItems && data.faqItems.length > 0 && (
        <div class="mt-16 lg:mt-24">
          <FaqAccordion client:load items={data.faqItems} heading={t('template.faq', locale)} />
        </div>
      )
    }

    {/* View All Workflows — injected by the route page */}
    <slot name="related" />
  </div>
</article>

<script is:inline define:vars={{ templateName: data.name }}>
  // Run on Cloud button — Vercel analytics
  document.querySelectorAll('.run-cloud-btn').forEach((link) => {
    link.addEventListener('click', () => {
      const loc = link.getAttribute('data-location') || 'hero';
      if (window.va) {
        window.va('event', { name: 'cta_click', template: templateName, location: loc });
      }
    });
  });

  // Download JSON button — Vercel analytics
  document.querySelectorAll('.download-json-btn').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.va) {
        window.va('event', { name: 'download_json', template: templateName });
      }
    });
  });

  // Share button
  const shareBtn = document.getElementById('share-workflow-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', function () {
      const url = window.location.href;

      function showCopied() {
        const textNode = shareBtn.lastChild;
        if (textNode) {
          const original = textNode.textContent;
          textNode.textContent = ' Link copied!';
          setTimeout(function () {
            textNode.textContent = original;
          }, 2000);
        }
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard
          .writeText(url)
          .then(showCopied)
          .catch(function () {
            fallbackCopy(url);
          });
      } else {
        fallbackCopy(url);
      }

      function fallbackCopy(text) {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.focus();
        textarea.select();
        try {
          document.execCommand('copy');
          showCopied();
        } catch {
          // silent fail
        }
        document.body.removeChild(textarea);
      }
    });
  }
</script>

<style>
  .media-frame :global(.video-thumb),
  .media-frame :global(.video-fallback-wrapper) {
    width: 100%;
    height: 100%;
  }
  .media-frame :global(img),
  .media-frame :global(video) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
