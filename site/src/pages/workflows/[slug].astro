---
/**
 * Legacy redirect: /workflows/[slug]/ → /workflows/[username]/[slug]/
 *
 * Pre-renders 301 redirects for all known workflows so old URLs
 * (bookmarks, search engine results) continue to work.
 *
 * Data source: Hub API (listWorkflowIndex) → fallback: content collection.
 */
import { DEFAULT_LOCALE } from '../../i18n/config';
import { getTemplatesForLocale } from '../../lib/templates';
import { listWorkflowIndex } from '../../lib/hub-api';
import { slugify } from '../../lib/slugify';

export async function getStaticPaths() {
  // Try hub API first — includes all workflows (backfilled + UGC)
  try {
    const entries = await listWorkflowIndex();
    return entries.map((entry) => ({
      params: { slug: entry.name },
      props: { username: slugify(entry.username || 'comfy') },
    }));
  } catch {
    // Fallback to content collection if hub API is unavailable
    const templates = await getTemplatesForLocale(DEFAULT_LOCALE);
    return templates.map((template) => ({
      params: { slug: template.data.name },
      props: { username: slugify(template.data.username || 'comfy') },
    }));
  }
}

const { slug } = Astro.params;
const { username } = Astro.props;

return Astro.redirect(`/workflows/${username}/${slug}/`, 301);
---
