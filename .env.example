# Local ComfyUI checkout used by maintenance scripts (e.g. API node model scanner,
# static node-compat scan). For live local checks, start ComfyUI and run
# npm run validate:comfyui-nodes (uses http://127.0.0.1:8188/object_info).
COMFYUI_REPO_PATH=/path/to/ComfyUI

# Optional override for live local /object_info checks:
# COMFYUI_OBJECT_INFO_URL=http://127.0.0.1:8188/object_info

# =============================================================================
# MCP AI enhancement (Step 2: enhance_models_registry.py, enhance_descriptions.py)
# =============================================================================
#
# Generic OpenAI-compatible Chat Completions API — NOT tied to a single vendor.
# Client calls: POST {AI_BASE_URL}/chat/completions  (Bearer auth, JSON body)
#
# Works with any provider that exposes that endpoint, for example:
#   OpenAI, OpenRouter, DeepSeek, Groq, Together, Fireworks, Moonshot,
#   local Ollama (/v1), LM Studio, vLLM, LiteLLM proxy, Azure OpenAI (compatible URL)
#
# Does NOT work with native-only APIs (Anthropic Messages, Gemini generateContent)
# unless you route through a compatible proxy (OpenRouter, LiteLLM, etc.).
#
# Pick ONE block below (uncomment / edit). Model id must match your provider's catalog.

# --- OpenAI (recommended default) ---
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o

# --- OpenRouter (multi-vendor gateway; model id = provider/model) ---
# AI_API_KEY=
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_MODEL=openai/gpt-4o
# AI_MODEL=anthropic/claude-sonnet-4-20250514
# AI_MODEL=google/gemini-2.5-pro-preview

# --- DeepSeek ---
# AI_API_KEY=
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# --- Groq ---
# AI_API_KEY=
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile

# --- Ollama (local; any string works as API key) ---
# AI_API_KEY=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.2

# --- LM Studio (local) ---
# AI_API_KEY=lm-studio
# AI_BASE_URL=http://localhost:1234/v1
# AI_MODEL=your-loaded-model-name
