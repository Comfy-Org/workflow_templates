# === Domain Configuration ===
# Canonical origin for SEO (scheme+host, no trailing slash, no path)
# Default: https://comfy.org (apex; set explicitly in Vercel production)
# Production: https://comfy.org
# PUBLIC_SITE_ORIGIN=https://comfy.org

# === Analytics ===
# PostHog project API key (public, safe to expose in client JS).
# Set in Vercel for production. If unset, PostHog is disabled.
# PUBLIC_POSTHOG_KEY=phc_...

# Google Analytics 4 measurement ID. If unset, GA4 is disabled.
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# === Ranking (Algolia) ===
# Popularity ("X runs" / Most Popular sort) is sourced at build time from the
# Algolia `templates_index` — real PostHog run-click usage published by the data
# platform. The search key is search-only and public-safe (same Algolia app the
# frontend uses). If unset, the build falls back to the backend `usage` field —
# no failure, just the previous behavior.
# PUBLIC_ALGOLIA_APP_ID=4E0RO38HS8
# PUBLIC_ALGOLIA_SEARCH_KEY=684d998c36b67a9a9fce8fc2d8860579
# PUBLIC_ALGOLIA_TEMPLATES_INDEX=templates_index

# === AI Content Generation ===
# OpenAI API key for AI content generation
OPENAI_API_KEY=sk-...

# Skip AI generation (use placeholder content)
# SKIP_AI_GENERATION=true
