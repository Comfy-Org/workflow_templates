---
import type { Locale } from '../../i18n/config';
import { t } from '../../i18n/ui';
import { localizeUrl } from '../../i18n/utils';
import { SITE_ORIGIN } from '../../config/site';

interface Crumb {
  label: string;
  href: string;
}

interface Props {
  locale: Locale;
  /** Title of the current page (rendered as the non-linked trailing crumb). */
  title: string;
  /** Extra crumbs inserted between Workflows and the title (e.g. Use Cases, Models). */
  trail?: Crumb[];
  class?: string;
}

const { locale, title, trail = [], class: className } = Astro.props;

const crumbs: Crumb[] = [
  { label: t('breadcrumb.home', locale), href: SITE_ORIGIN },
  { label: t('breadcrumb.workflows', locale), href: localizeUrl('/workflows/', locale) },
  ...trail,
];
---

<nav aria-label="Breadcrumb" class:list={['text-sm', className]}>
  <ol class="flex items-center gap-2 text-content-muted min-w-0">
    {
      crumbs.map((crumb) => (
        <li class="flex items-center gap-2 shrink-0">
          <a href={crumb.href} class="hover:text-content transition-colors" data-astro-prefetch>
            {crumb.label}
          </a>
          <svg
            class="size-3.5 text-content-muted/50 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M9 6l6 6-6 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </li>
      ))
    }
    <li class="min-w-0">
      <span class="text-content line-clamp-1" aria-current="page">{title}</span>
    </li>
  </ol>
</nav>
