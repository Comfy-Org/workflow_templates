---
/**
 * Localized model page (on-demand rendered)
 * Serves pages like /zh/workflows/model/flux/, /ja/workflows/model/sdxl/, etc.
 */
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import HubNavbar from '../../../../components/hub/HubNavbar.astro';
import SiteFooter from '../../../../components/hub/SiteFooter.astro';
import WorkflowGrid from '../../../../components/hub/WorkflowGrid.vue';
import BackButton from '../../../../components/BackButton.astro';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../../i18n/config';
import { localizeUrl } from '../../../../i18n/utils';
import { t } from '../../../../i18n/ui';
import { slugify } from '../../../../lib/slugify';
import { absoluteUrl } from '../../../../config/site';
import { modelPath } from '../../../../lib/routes';
import { badgeVariants } from '../../../../components/ui/badge';
import { loadSerializedTemplates } from '../../../../lib/hub-api';
import { buildToolbarLabels } from '../../../../lib/toolbar';
import {
  buildCollectionPageJsonLd,
  buildWorkflowBreadcrumb,
  serializeJsonLdForScript,
} from '../../../../lib/structured-data';

const { locale, name } = Astro.params;

// Validate locale
if (!locale || !LOCALES.includes(locale as Locale) || locale === DEFAULT_LOCALE) {
  return Astro.redirect(`/workflows/model/${name || ''}/`);
}

const typedLocale = locale as Locale;

const allTemplates = await loadSerializedTemplates(() => getCollection('templates'));

// Find templates matching this model slug
const matchingTemplates = allTemplates.filter((tmpl) =>
  tmpl.models.some((m: string) => slugify(m) === name)
);

if (matchingTemplates.length === 0) {
  return Astro.redirect(`/${locale}/workflows/`);
}

// Get display name from the first matching model
const modelName =
  matchingTemplates[0]?.models?.find((m: string) => slugify(m) === name) || name || '';

const basePath = modelPath(name!);
const canonicalUrl = absoluteUrl(localizeUrl(basePath, typedLocale));

const title = `${modelName} ComfyUI Workflows - Free Templates`;
const description = `Browse ${matchingTemplates.length} free ComfyUI workflow templates using ${modelName}. Ready-to-use AI generation workflows for image, video, and audio creation.`;

const structuredData = buildCollectionPageJsonLd({
  name: `${modelName} ComfyUI Workflows`,
  description,
  url: canonicalUrl,
  inLanguage: locale,
});

const breadcrumbStructuredData = buildWorkflowBreadcrumb(
  typedLocale,
  { name: modelName },
  {
    name: t('labels.models', typedLocale),
    item: absoluteUrl(localizeUrl('/workflows/model/', typedLocale)),
  }
);

// matchingTemplates are already SerializedTemplate[] with profile data
const serialized = matchingTemplates;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/workflows/og-default.png"
  structuredData={structuredData}
  locale={typedLocale}
  hreflangBasePath={basePath}
  theme="dark"
  hideDefaultFooter
>
  <HubNavbar />
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-16 py-12">
    <!-- Back -->
    <nav class="mb-8">
      <BackButton locale={typedLocale} />
    </nav>

    <!-- Header -->
    <div class="mb-12">
      <span class={badgeVariants({ variant: 'hub-pill' })}>{t('labels.models', typedLocale)}</span>
      <h1 class="text-3xl font-bold text-content mt-3">
        {modelName} ComfyUI Workflows
      </h1>
      <p class="text-content-muted text-base mt-2">
        {matchingTemplates.length}
        {t('template.count', typedLocale)}
      </p>
    </div>

    <!-- Interactive Grid -->
    <WorkflowGrid
      client:load
      templates={serialized}
      locale={typedLocale}
      toolbarLabels={buildToolbarLabels(typedLocale)}
      gridClass="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
    />
  </div>

  <script
    is:inline
    type="application/ld+json"
    set:html={serializeJsonLdForScript(breadcrumbStructuredData)}
  />

  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
