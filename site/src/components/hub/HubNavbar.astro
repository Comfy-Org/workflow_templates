---
import { getCollection } from 'astro:content';
import { getLocaleFromPath, localizeUrl } from '../../i18n/utils';
import SearchPopover from './SearchPopover.vue';
import creatorsData from '../../../../templates/creators.json';

type SearchTemplate = {
  name: string;
  title: string;
  description: string;
  mediaType: 'image' | 'video' | 'audio' | '3d';
  tags: string[];
  models: string[];
  logos: { provider: string | string[] }[];
  usage: number;
  date: string;
  thumbnails: string[];
  username: string;
  creatorDisplayName: string;
};

interface Props {
  templates?: SearchTemplate[];
}

const creators = creatorsData as Record<string, { displayName: string }>;
const locale = getLocaleFromPath(Astro.url.pathname);

// Use provided templates or fetch and serialize them
let templates: SearchTemplate[];
if (Astro.props.templates && Astro.props.templates.length > 0) {
  templates = Astro.props.templates;
} else {
  const allTemplates = (await getCollection('templates'))
    .filter((tmpl) => !tmpl.id.includes('/'))
    .sort((a, b) => (b.data.usage || 0) - (a.data.usage || 0));

  templates = allTemplates.map((tmpl) => ({
    name: tmpl.data.name,
    title: tmpl.data.title || tmpl.data.name,
    description: tmpl.data.description || '',
    mediaType: tmpl.data.mediaType,
    tags: tmpl.data.tags || [],
    models: tmpl.data.models || [],
    logos: tmpl.data.logos || [],
    usage: tmpl.data.usage || 0,
    date: tmpl.data.date || '',
    thumbnails: tmpl.data.thumbnails || [],
    username: tmpl.data.username || '',
    creatorDisplayName:
      (tmpl.data.username && creators[tmpl.data.username]?.displayName) || 'ComfyUI',
  }));
}
---

<nav class="w-full bg-[var(--color-bg-page)] sticky top-0 z-50">
  <div class="max-w-400 mx-auto h-16 lg:h-20 px-4 sm:px-6 lg:px-16 flex items-center gap-3 lg:gap-16">
    <!-- Left: Logo -->
    <a href={localizeUrl('/', locale)} class="shrink-0">
      <img
        src="/brand/comfy-c-yellow.svg"
        alt="Comfy"
        class="h-8 w-12 lg:hidden"
      />
      <img
        src="/brand/comfy-hub-logo.svg"
        alt="Comfy"
        class="hidden lg:block h-8 w-auto"
      />
    </a>

    <!-- Center: Search Popover (Vue island) -->
    <SearchPopover
      client:load
      templates={templates}
      locale={locale}
    />

    <!-- Right: Actions (desktop) -->
    <div class="hidden lg:flex items-center gap-4 shrink-0">
      <a
        href="https://cloud.comfy.org/cloud/signup?utm_source=workflow_hub&utm_medium=inhouse_social&utm_campaign=free_tier&utm_content=post"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center h-10 px-5 rounded-full bg-brand text-page text-sm font-bold hover:opacity-90 transition-opacity whitespace-nowrap"
      >
        Get free credits
      </a>
    </div>

    <!-- Right: Hamburger (mobile) -->
    <button
      id="mobile-filter-toggle"
      type="button"
      class="lg:hidden shrink-0 flex items-center justify-center size-10 rounded-full text-white/70 hover:text-white hover:bg-white/5 active:bg-white/10 transition-colors"
      aria-label="Open filters"
    >
      <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </div>
</nav>
