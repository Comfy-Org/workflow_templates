---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubNavbar from '../../components/hub/HubNavbar.astro';
import HubHero from '../../components/hub/HubHero.astro';
import HubSearchBar from '../../components/hub/HubSearchBar.astro';
import HubBrowse from '../../components/hub/HubBrowse.vue';
import FeaturedCarousel from '../../components/hub/FeaturedCarousel.vue';
import SiteFooter from '../../components/hub/SiteFooter.astro';
import { getLocaleFromPath, localizeUrl, isRTL } from '../../i18n/utils';
import { t } from '../../i18n/ui';
import { absoluteUrl } from '../../config/site';
import { loadSerializedTemplates } from '../../lib/hub-api';
import { getFeatured, featuredPreloadImage } from '../../lib/featured';
import { buildToolbarLabels, buildFacetsConfig } from '../../lib/toolbar';

const locale = getLocaleFromPath(Astro.url.pathname);

const serialized = await loadSerializedTemplates(() => getCollection('templates'));

const featured = getFeatured(serialized);
const featuredLcpImage = featuredPreloadImage(featured);

const canonicalUrl = absoluteUrl(localizeUrl('/workflows/', locale));

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t('meta.title', locale),
  description: t('meta.description', locale),
  url: canonicalUrl,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: serialized.length,
  },
};

const mediaTypes = ['image', 'video', 'audio', '3d'];

// Toolbar labels + filter facets, resolved once here (Vue islands never import
// i18n). Shared builders keep these identical across every page that mounts a grid.
const toolbarLabels = buildToolbarLabels(locale);
const facetsConfig = buildFacetsConfig(locale);
---

<BaseLayout
  title={`${t('meta.title', locale)} - Free AI Generation Workflows`}
  description={t('meta.description', locale)}
  canonicalUrl={canonicalUrl}
  ogImage="/workflows/og-default.png"
  structuredData={structuredData}
  theme="dark"
  hideDefaultFooter
>
  {
    featuredLcpImage && (
      <link slot="head" rel="preload" as="image" href={featuredLcpImage} fetchpriority="high" />
    )
  }

  <!-- Sticky navbar (matches other pages); the inline search docks beneath it on scroll. -->
  <HubNavbar showSearch={false} sticky />

  <div class="max-w-400 mx-auto px-6 lg:px-[clamp(0.25rem,4vw,5rem)]">
    <!-- Featured hero carousel (Vue island) -->
    <FeaturedCarousel
      client:load
      templates={featured}
      locale={locale}
      isRtl={isRTL(locale)}
      featuredLabel={t('hub.featured.label', locale)}
      prevLabel={t('hub.featured.prev', locale)}
      nextLabel={t('hub.featured.next', locale)}
    />

    <HubHero count={serialized.length} />

    <!-- Inline search — shows among the filters, docks flush below the navbar once scrolled past. -->
    <HubSearchBar templates={serialized} locale={locale} />

    <!-- Interactive browse (Vue island) -->
    <HubBrowse
      client:load
      templates={serialized}
      locale={locale}
      mediaTypes={mediaTypes}
      facetsConfig={facetsConfig}
      toolbarLabels={toolbarLabels}
    />
  </div>

  <!-- Custom Footer -->
  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
