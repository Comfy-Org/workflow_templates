---
/**
 * Workflow detail page — pre-rendered at build time.
 * URL: /workflows/{name}-{share_id}/
 *
 * Legacy URLs without a share_id 301-redirect to the canonical format.
 * Data source: listWorkflowIndex(), falling back to the content collection.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import HubNavbar from '../../components/hub/HubNavbar.astro';
import SiteFooter from '../../components/hub/SiteFooter.astro';
import TemplateDetailPage from '../../components/template-detail/TemplateDetailPage.astro';
import WorkflowGrid from '../../components/hub/WorkflowGrid.vue';
import { DEFAULT_LOCALE } from '../../i18n/config';
import { getTemplatesForLocale } from '../../lib/templates';
import { absoluteUrl } from '../../config/site';
import {
  listWorkflowIndex,
  listRelatedWorkflows,
  getSerializedIndex,
  type HubWorkflowTemplateEntry,
  type SerializedTemplate,
} from '../../lib/hub-api';
import { workflowOgUrl } from '../../lib/og-url';
import {
  buildFaqJsonLd,
  serializeJsonLdForScript,
  buildWorkflowBreadcrumb,
} from '../../lib/structured-data';
import { buildToolbarLabels } from '../../lib/toolbar';

import { localizeUrl } from '../../i18n/utils';
import { t } from '../../i18n/ui';

export async function getStaticPaths() {
  let entries: HubWorkflowTemplateEntry[] = [];
  try {
    entries = await listWorkflowIndex();
  } catch {
    const templates = await getTemplatesForLocale(DEFAULT_LOCALE);
    return templates
      .filter((tmpl) => Boolean(tmpl.data.name))
      .map((tmpl) => ({
        params: { slug: tmpl.data.name },
        props: { entry: null, legacySlug: tmpl.data.name, legacyShareId: null },
      }));
  }

  const paths = [];

  for (const entry of entries) {
    const shareId = entry.shareId || '';
    const name = entry.name || shareId;
    if (!name) continue;

    if (shareId) {
      paths.push({
        params: { slug: `${name}-${shareId}` },
        props: { entry, legacySlug: null, legacyShareId: null },
      });
      // Legacy /workflows/{name}/ redirects to the canonical slug. Also covers
      // UGC where name == shareId (card links point at /workflows/{name}/).
      paths.push({
        params: { slug: name },
        props: { entry: null, legacySlug: name, legacyShareId: shareId },
      });
    } else {
      // No shareId — render directly, no redirect needed.
      paths.push({
        params: { slug: name },
        props: { entry, legacySlug: null, legacyShareId: null },
      });
    }
  }

  return paths;
}

interface Props {
  entry: HubWorkflowTemplateEntry | null;
  legacySlug: string | null;
  legacyShareId: string | null;
}

const { entry, legacySlug, legacyShareId } = Astro.props;

if (!entry && legacySlug) {
  if (legacyShareId) {
    return Astro.redirect(`/workflows/${legacySlug}-${legacyShareId}/`, 301);
  }
  return Astro.redirect('/workflows/');
}

if (!entry) {
  return Astro.redirect('/workflows/');
}

const locale = DEFAULT_LOCALE;
const data = {
  name: entry.name,
  shareId: entry.shareId || '',
  title: entry.title || entry.name,
  description: entry.description || '',
  mediaType: entry.mediaType || 'image',
  mediaSubtype: entry.mediaSubtype,
  thumbnailVariant: entry.thumbnailVariant,
  thumbnails: [entry.thumbnailUrl, entry.thumbnailComparisonUrl].filter(Boolean) as string[],
  tags: entry.tags || [],
  models: entry.models || [],
  username: entry.profile?.username || entry.username || '',
  date: entry.date || '',
  tutorialUrl: entry.tutorialUrl,
  extendedDescription: entry.extendedDescription || '',
  metaDescription: entry.metaDescription || entry.description || '',
  howToUse: entry.howToUse || [],
  suggestedUseCases: entry.suggestedUseCases || [],
  faqItems: entry.faqItems || [],
  contentTemplate: entry.contentTemplate,
};

const title = `${data.title} - ComfyUI Workflow`;
const urlSlug = `${data.name}-${data.shareId}`;
const canonicalUrl = absoluteUrl(`/workflows/${urlSlug}/`);

const thumbnails = data.thumbnails;
const primaryThumbnail = thumbnails[0] || null;
const ogImage = workflowOgUrl(
  data.title || data.name,
  primaryThumbnail ? primaryThumbnail : undefined,
  data.username || undefined
);

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: data.title,
  description: data.description,
  image: primaryThumbnail || undefined,
  datePublished: data.date,
  inLanguage: 'en',
};

const faqStructuredData = buildFaqJsonLd(data.faqItems);

const breadcrumbStructuredData = buildWorkflowBreadcrumb(locale, {
  name: data.title,
  item: canonicalUrl,
});

const softwareAppStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: data.title,
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Windows, macOS, Linux',
  description: data.metaDescription || data.description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const relatedTemplates: SerializedTemplate[] = await listRelatedWorkflows(data.name);
const toolbarLabels = buildToolbarLabels(locale);

// Reverse internal links: SEO use-case pages whose cluster includes this
// workflow. Built from the once-serialized index (stable reference), so the
// membership map is computed a single time across all detail pages.
const catalog = await getSerializedIndex();
// const relatedUseCases = useCasePagesFeaturingTemplate(data.name, catalog).map((def) => ({
//   label: def.h1,
//   href: localizeUrl(useCasePath(def.slug), locale),
// }));
---

<BaseLayout
  title={title}
  description={data.metaDescription || data.description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  structuredData={structuredData}
  hreflangBasePath={`/workflows/${urlSlug}/`}
  theme="dark"
  hideDefaultFooter
>
  <HubNavbar />
  <TemplateDetailPage template={{ data }} locale={locale}>
    {
      relatedTemplates.length > 0 && (
        <section slot="related" class="mt-16 lg:mt-24">
          <a
            href={localizeUrl('/workflows/', locale)}
            class="inline-block text-2xl lg:text-3xl font-semibold text-content hover:opacity-80 transition-opacity mb-6 lg:mb-8"
          >
            {t('template.viewAllWorkflows', locale)}
          </a>
          <WorkflowGrid
            client:visible
            templates={relatedTemplates}
            locale={locale}
            toolbarLabels={toolbarLabels}
            gridClass="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
          />
        </section>
      )
    }
  </TemplateDetailPage>

  {
    faqStructuredData && (
      <script
        is:inline
        type="application/ld+json"
        set:html={serializeJsonLdForScript(faqStructuredData)}
      />
    )
  }
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeJsonLdForScript(softwareAppStructuredData)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={serializeJsonLdForScript(breadcrumbStructuredData)}
  />

  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
