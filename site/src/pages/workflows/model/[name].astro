---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubNavbar from '../../../components/hub/HubNavbar.astro';
import SiteFooter from '../../../components/hub/SiteFooter.astro';
import WorkflowGrid from '../../../components/hub/WorkflowGrid.vue';
import Breadcrumbs from '../../../components/template-detail/Breadcrumbs.astro';
import SeoPageBody from '../../../components/seo/SeoPageBody.astro';
import HeroSection from '../../../components/seo/HeroSection.astro';
import RelatedRail from '../../../components/seo/RelatedRail.astro';
import { inner, eyebrow, heading } from '../../../components/seo/seo-styles';
import { getLocaleFromPath, localizeUrl } from '../../../i18n/utils';
import { t } from '../../../i18n/ui';
import { isMediaFile } from '../../../lib/media-utils';
import { SITE_ORIGIN, absoluteUrl } from '../../../config/site';
import { modelPath, useCasePath, thumbnailPath } from '../../../lib/routes';
import { getCloudCtaUrl, getCloudLandingUrl } from '../../../lib/urls';
import { buildToolbarLabels } from '../../../lib/toolbar';
import { loadSerializedTemplates, type SerializedTemplate } from '../../../lib/hub-api';
import { deriveModelGroups, type ModelGroup } from '../../../lib/seo/model-groups';
import { loadModelContent } from '../../../lib/seo/content-loaders';
import { useCasesFeaturingModel } from '../../../lib/seo/use-case-resolver';
import { type SeoPageDef } from '../../../config/seo-pages';
import { isIndexable } from '../../../lib/seo/governance';
import {
  buildCollectionPageJsonLd,
  buildBreadcrumbJsonLd,
  buildFaqJsonLd,
  serializeJsonLdForScript,
} from '../../../lib/structured-data';

export async function getStaticPaths() {
  const catalog = await loadSerializedTemplates(() => getCollection('templates'));
  const groups = deriveModelGroups(catalog);
  // Image fallback pool: every template that has a still, so a section can draw
  // a content-matched image from the whole dataset before any image repeats.
  // Trimmed to the fields the matcher reads, to keep the page payload lean.
  const fallbackPool = catalog
    .filter((t) => t.thumbnails?.some((thumb) => !/\.(mp4|mov|mp3|webm)(\?|#|$)/i.test(thumb)))
    .map((t) => ({
      name: t.name,
      title: t.title,
      description: t.description,
      tags: t.tags,
      models: t.models,
      usage: t.usage,
      thumbnails: t.thumbnails,
    })) as SerializedTemplate[];
  const paths: {
    params: { name: string };
    props: {
      group: ModelGroup;
      relatedUseCases: SeoPageDef[];
      fallbackPool: SerializedTemplate[];
      redirectTo?: string;
    };
  }[] = [];

  for (const group of groups) {
    const relatedUseCases = useCasesFeaturingModel(group.slug, catalog);
    paths.push({ params: { name: group.slug }, props: { group, relatedUseCases, fallbackPool } });
    for (const variant of group.redirectFrom) {
      paths.push({
        params: { name: variant },
        props: { group, relatedUseCases, fallbackPool, redirectTo: group.slug },
      });
    }
  }
  return paths;
}

const {
  group,
  relatedUseCases: relatedUseCaseDefs,
  fallbackPool,
  redirectTo,
} = Astro.props as {
  group: ModelGroup;
  relatedUseCases: SeoPageDef[];
  fallbackPool: SerializedTemplate[];
  redirectTo?: string;
};
const locale = getLocaleFromPath(Astro.url.pathname);

if (redirectTo) {
  return Astro.redirect(localizeUrl(modelPath(redirectTo), locale), 301);
}

const { label, templates, keywords } = group;
const content = await loadModelContent(group.slug);
const basePath = modelPath(group.slug);
const canonicalUrl = absoluteUrl(localizeUrl(basePath, locale));

const isRich = group.qualifies && !!content && !content.qualityFailed;
const h1 = `${label} ComfyUI Workflows`;
const title = content
  ? `${label} ComfyUI Workflows — Ready-to-Run Templates`
  : `${label} Workflows`;
const description =
  content?.metaDescription ||
  `Browse ${templates.length} ready-to-use ComfyUI workflow templates using ${label}. AI generation workflows that run on Comfy Cloud with no setup.`;
const subheading =
  content?.subheading ||
  `Ready-to-run ComfyUI workflows built on ${label}, fully editable and runnable on Comfy Cloud with no setup.`;

const noindex =
  !isRich ||
  !isIndexable({ clusterSize: templates.length, humanEdited: true, qualityPassed: true });

const leadShareId = templates.find((template) => template.shareId)?.shareId;
const heroCtaUrl = leadShareId
  ? getCloudCtaUrl(leadShareId, `model_${group.slug}_hero`)
  : getCloudLandingUrl(`model_${group.slug}_hero`);
const footerCtaUrl = leadShareId
  ? getCloudCtaUrl(leadShareId, `model_${group.slug}_footer`)
  : getCloudLandingUrl(`model_${group.slug}_footer`);

const modelsUrl = absoluteUrl(localizeUrl('/workflows/model/', locale));
const breadcrumbTrail = [
  { label: t('labels.models', locale), href: localizeUrl('/workflows/model/', locale) },
];

const structuredData = buildCollectionPageJsonLd({ name: h1, description, url: canonicalUrl });
const breadcrumbStructuredData = buildBreadcrumbJsonLd([
  { name: t('breadcrumb.home', locale), item: SITE_ORIGIN },
  {
    name: t('breadcrumb.workflows', locale),
    item: absoluteUrl(localizeUrl('/workflows/', locale)),
  },
  { name: t('labels.models', locale), item: modelsUrl },
  { name: h1 },
]);
const faqStructuredData = isRich ? buildFaqJsonLd(content!.faqItems) : null;

// The template whose still becomes the hero image — reserved so no section reuses it.
const heroTemplateName = group.templates.find((tpl) =>
  tpl.thumbnails?.some((thumb) => !isMediaFile(thumb))
)?.name;

// "Keep exploring" image cards: use-cases featuring this model family (derived
// from grid overlap), each borrowing a still from this page's own grid.
const useCasePoolStills = group.templates
  .flatMap((tpl) => tpl.thumbnails ?? [])
  .filter((thumb) => !isMediaFile(thumb));

const relatedCards = isRich
  ? relatedUseCaseDefs.slice(0, 6).map((def, i) => ({
      title: def.h1,
      eyebrow: t('template.useCases', locale),
      href: localizeUrl(useCasePath(def.slug), locale),
      logo: null,
      image: useCasePoolStills[i]
        ? { src: thumbnailPath(useCasePoolStills[i]), alt: def.h1 }
        : null,
    }))
  : [];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/workflows/og-default.png"
  structuredData={structuredData}
  locale={locale}
  hreflangBasePath={basePath}
  theme="dark"
  noindex={noindex}
  hideDefaultFooter
>
  <HubNavbar />

  <article class="bg-page min-h-screen text-content scroll-smooth hyphens-none wrap-normal">
    <div class:list={[inner, 'pt-4 lg:pt-6']}>
      <Breadcrumbs locale={locale} title={h1} trail={breadcrumbTrail} />
    </div>
    <HeroSection
      eyebrow={t('labels.models', locale)}
      title={h1}
      description={subheading}
      meta={`${group.templates.length} ${t('useCase.workflowsCount', locale)}`}
      primaryCta={{ label: t('cta.tryCloud', locale), href: heroCtaUrl }}
      secondaryCta={{ label: t('template.viewAllWorkflows', locale), href: '#workflows' }}
      templates={group.templates}
    />

    <section id="workflows" class="scroll-mt-8 bg-page pt-20 pb-10 lg:pt-28 lg:pb-12">
      <div class={inner}>
        <p class={eyebrow}>{t('useCase.theWorkflows', locale)}</p>
        <h2 class={`${heading} mb-8 lg:mb-10`}>
          {templates.length}
          {h1}
        </h2>
        <WorkflowGrid
          client:load
          templates={templates}
          locale={locale}
          toolbarLabels={buildToolbarLabels(locale)}
          gridClass="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
        />
      </div>
    </section>

    {
      isRich && (
        <SeoPageBody
          locale={locale}
          kind="model"
          keyword={keywords.primary}
          intro={content!.extendedDescription}
          modelSpec={content!.modelSpec}
          specName={label}
          capabilitiesIntro={content!.capabilitiesIntro}
          whyComfy={content!.whyComfy}
          applicationsIntro={content!.applicationsIntro}
          suggestedUseCases={content!.suggestedUseCases}
          faqItems={content!.faqItems}
          templates={group.templates}
          catalog={fallbackPool}
          reservedTemplates={heroTemplateName ? [heroTemplateName] : []}
          ctaLabel={t('useCase.tryWorkflow', locale)}
          ctaHref={(tpl) =>
            tpl.shareId
              ? getCloudCtaUrl(tpl.shareId, `model_${group.slug}_capability`)
              : getCloudLandingUrl(`model_${group.slug}_capability`)
          }
          banner={{
            title: t('useCase.bannerTitle', locale),
            body: t('useCase.bannerBody', locale),
            kicker: t('useCase.bannerKicker', locale),
            cta: {
              label: t('useCase.bannerCta', locale),
              href: getCloudLandingUrl(`model_${group.slug}_banner`),
            },
          }}
        />
      )
    }

    {relatedCards.length > 0 && <RelatedRail locale={locale} cards={relatedCards} />}

    {
      isRich && (
        <section class="bg-page py-20 lg:py-28">
          <div class={`${inner} flex flex-col items-center text-center`}>
            <h2 class="font-display text-3xl lg:text-4xl font-semibold tracking-tight text-content-bright">
              {t('template.ready', locale)}
            </h2>
            <p class="font-body mt-3 max-w-xl text-base text-content-secondary">
              {t('template.startNow', locale)}
            </p>
            <a
              href={footerCtaUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center justify-center rounded-full bg-brand px-8 py-3.5 text-sm font-bold text-page transition-opacity hover:opacity-90"
            >
              {t('cta.tryCloud', locale)}
            </a>
          </div>
        </section>
      )
    }
  </article>

  <script
    is:inline
    type="application/ld+json"
    set:html={serializeJsonLdForScript(breadcrumbStructuredData)}
  />
  {
    faqStructuredData && (
      <script
        is:inline
        type="application/ld+json"
        set:html={serializeJsonLdForScript(faqStructuredData)}
      />
    )
  }

  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
