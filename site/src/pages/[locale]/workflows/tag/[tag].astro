---
/**
 * Localized tag page (on-demand rendered)
 * Serves pages like /zh/workflows/tag/portrait/, /ja/workflows/tag/upscale/, etc.
 */
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import HubNavbar from '../../../../components/hub/HubNavbar.astro';
import SiteFooter from '../../../../components/hub/SiteFooter.astro';
import WorkflowGrid from '../../../../components/hub/WorkflowGrid.vue';
import HreflangTags from '../../../../components/HreflangTags.astro';
import BackButton from '../../../../components/BackButton.astro';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../../i18n/config';
import { t } from '../../../../i18n/ui';
import { localizeUrl } from '../../../../i18n/utils';
import { getTemplatesForLocale } from '../../../../lib/templates';
import { tagSlug, tagDisplayName } from '../../../../lib/tag-aliases';
import { SITE_ORIGIN, absoluteUrl } from '../../../../config/site';
import { badgeVariants } from '../../../../components/ui/badge';
import creatorsData from '../../../../../creators.json';

const creators = creatorsData as Record<string, { displayName: string }>;

const { locale, tag } = Astro.params;

// Validate locale
if (!locale || !LOCALES.includes(locale as Locale) || locale === DEFAULT_LOCALE) {
  return Astro.redirect(`/workflows/tag/${tag || ''}/`);
}

const typedLocale = locale as Locale;

// Get templates for this locale
const allTemplates = await getTemplatesForLocale(typedLocale);

// Find templates matching this tag slug
const matchingTemplates = allTemplates
  .filter((tmpl) => {
    const tags = tmpl.data.tags || [];
    return tags.some((t: string) => tagSlug(t) === tag);
  })
  .sort((a, b) => (b.data.usage || 0) - (a.data.usage || 0));

if (matchingTemplates.length === 0) {
  return Astro.redirect(`/${locale}/workflows/`);
}

// Get display name from the first matching tag
const firstMatchingTag = matchingTemplates[0].data.tags?.find(
  (t: string) => tagSlug(t) === tag
) || tag || '';
const tagName = tagDisplayName(firstMatchingTag);

const basePath = `/workflows/tag/${tag}/`;
const canonicalUrl = absoluteUrl(localizeUrl(basePath, typedLocale));

const title = `${tagName} ComfyUI Workflows - ${t('nav.templates', typedLocale)}`;
const description = `Browse ${matchingTemplates.length} ComfyUI workflow templates tagged with "${tagName}". Free, ready-to-use AI generation workflows.`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${tagName} ComfyUI Workflows`,
  description,
  url: canonicalUrl,
  inLanguage: locale,
};

const breadcrumbStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_ORIGIN },
    {
      '@type': 'ListItem',
      position: 2,
      name: t('nav.templates', typedLocale),
      item: absoluteUrl(localizeUrl('/workflows/', typedLocale)),
    },
    { '@type': 'ListItem', position: 3, name: tagName },
  ],
};

// Serialize templates for the Vue WorkflowGrid island
const serialized = matchingTemplates.map((tmpl) => ({
  name: tmpl.data.name,
  title: tmpl.data.title || tmpl.data.name,
  tags: tmpl.data.tags || [],
  logos: tmpl.data.logos || [],
  usage: tmpl.data.usage || 0,
  date: tmpl.data.date || '',
  thumbnails: tmpl.data.thumbnails || [],
  username: tmpl.data.username || '',
  creatorDisplayName:
    (tmpl.data.username && creators[tmpl.data.username]?.displayName) || 'ComfyUI',
  isApp: tmpl.data.isApp || false,
}));
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage="/og-default.png"
  structuredData={structuredData}
  locale={typedLocale}
  hreflangBasePath={basePath}
  theme="dark"
  hideDefaultFooter
>
  <HreflangTags basePath={basePath} slot="head" />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbStructuredData)}
  />

  <HubNavbar />
  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-16 py-12">
    <!-- Back -->
    <nav class="mb-8">
      <BackButton locale={typedLocale} />
    </nav>

    <!-- Header -->
    <div class="mb-12 text-center">
      <span class={badgeVariants({ variant: 'hub-pill' })}>Tag</span>
      <h1 class="text-3xl font-bold text-white mt-3">
        {tagName}
      </h1>
      <p class="text-hub-muted text-base mt-2">
        {matchingTemplates.length} workflow{matchingTemplates.length !== 1 ? 's' : ''}
      </p>
    </div>

    <!-- Interactive Grid -->
    <WorkflowGrid
      client:load
      templates={serialized}
      locale={typedLocale}
      gridClass="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
    />
  </div>

  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
