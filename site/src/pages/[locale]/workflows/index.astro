---
/**
 * Localized templates index page (on-demand rendered)
 * Serves pages like /zh/workflows/, /ja/workflows/, etc.
 * Rendered at the edge on first request, then cached by Vercel CDN.
 */
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubNavbar from '../../../components/hub/HubNavbar.astro';
import HubHero from '../../../components/hub/HubHero.astro';
import HubSearchBar from '../../../components/hub/HubSearchBar.astro';
import HubBrowse from '../../../components/hub/HubBrowse.vue';
import FeaturedCarousel from '../../../components/hub/FeaturedCarousel.vue';
import SiteFooter from '../../../components/hub/SiteFooter.astro';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../../i18n/config';
import { isRTL } from '../../../i18n/utils';
import { t } from '../../../i18n/ui';
import { absoluteUrl } from '../../../config/site';
import { loadSerializedTemplates } from '../../../lib/hub-api';
import { getFeatured, featuredPreloadImage } from '../../../lib/featured';
import { buildToolbarLabels, buildFacetsConfig } from '../../../lib/toolbar';

const { locale } = Astro.params;

// Validate locale
if (!locale || !LOCALES.includes(locale as Locale) || locale === DEFAULT_LOCALE) {
  return Astro.redirect('/workflows/');
}

const typedLocale = locale as Locale;

const serialized = await loadSerializedTemplates(() => getCollection('templates'));

const featured = getFeatured(serialized);
const featuredLcpImage = featuredPreloadImage(featured);

const canonicalUrl = absoluteUrl('/' + locale + '/workflows/');

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t('meta.title', typedLocale),
  description: t('meta.description', typedLocale),
  url: canonicalUrl,
  inLanguage: locale,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: serialized.length,
  },
};

const mediaTypes = ['image', 'video', 'audio', '3d'];

// Toolbar labels + filter facets, resolved once here (Vue islands never import
// i18n). Shared builders keep these identical across every page that mounts a grid.
const toolbarLabels = buildToolbarLabels(typedLocale);
const facetsConfig = buildFacetsConfig(typedLocale);
---

<BaseLayout
  title={`${t('meta.title', typedLocale)} - ComfyUI`}
  description={t('meta.description', typedLocale)}
  canonicalUrl={canonicalUrl}
  ogImage="/brand/og-default-v2.png"
  ogDescription={t('meta.ogDescription', typedLocale)}
  structuredData={structuredData}
  locale={typedLocale}
  hreflangBasePath="/workflows/"
  theme="dark"
  hideDefaultFooter
>
  {
    featuredLcpImage && (
      <link slot="head" rel="preload" as="image" href={featuredLcpImage} fetchpriority="high" />
    )
  }

  <!-- Sticky navbar (matches other pages); the inline search docks beneath it on scroll. -->
  <HubNavbar showSearch={false} sticky />

  <div class="max-w-400 mx-auto px-6 lg:px-[clamp(0.25rem,4vw,5rem)]">
    <!-- Featured hero carousel (Vue island) -->
    <FeaturedCarousel
      client:load
      templates={featured}
      locale={typedLocale}
      isRtl={isRTL(typedLocale)}
      featuredLabel={t('hub.featured.label', typedLocale)}
      prevLabel={t('hub.featured.prev', typedLocale)}
      nextLabel={t('hub.featured.next', typedLocale)}
    />

    <HubHero count={serialized.length} />

    <!-- Inline search — shows among the filters, docks flush below the navbar once scrolled past. -->
    <HubSearchBar templates={serialized} locale={typedLocale} />

    <!-- Interactive browse (Vue island) -->
    <HubBrowse
      client:load
      templates={serialized}
      locale={typedLocale}
      mediaTypes={mediaTypes}
      facetsConfig={facetsConfig}
      toolbarLabels={toolbarLabels}
    />
  </div>

  <!-- Custom Footer -->
  <Fragment slot="footer">
    <SiteFooter />
  </Fragment>
</BaseLayout>
