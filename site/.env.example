# === Domain Configuration ===
# Canonical origin for SEO (scheme+host, no trailing slash, no path)
# Default: https://templates.comfy.org
# Production: https://comfy.org
# PUBLIC_SITE_ORIGIN=https://comfy.org

# === Analytics ===
# PostHog: staging vs production is auto-detected by hostname (comfy.org = prod).
# Keys are hardcoded in src/lib/posthog.ts — no env vars needed.

# === AI Content Generation ===
# OpenAI API key for AI content generation
OPENAI_API_KEY=sk-...

# Skip AI generation (use placeholder content)
# SKIP_AI_GENERATION=true
