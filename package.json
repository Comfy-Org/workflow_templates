{
  "name": "comfyui-workflow-templates-monorepo",
  "private": true,
  "devDependencies": {
    "nx": "19.8.14"
  },
  "scripts": {
    "graph": "NX_ADD_PLUGINS=false NX_DAEMON=false npx nx graph --watch=false --open=false",
    "sync": "NX_ADD_PLUGINS=false NX_DAEMON=false npx nx run tooling:sync --skip-nx-cache",
    "sync:templates": "python scripts/sync/sync_data.py --templates-dir templates",
    "sync:bundles": "python scripts/sync/sync_bundles.py",
    "i18n": "python scripts/sync/sync_data.py --templates-dir templates",
    "mcp": "python scripts/mcp/sync_index.py",
    "mcp:check": "python scripts/mcp/sync_index.py --check",
    "mcp:ai": "python scripts/mcp/enhance_descriptions.py",
    "mcp:models": "python scripts/mcp/enhance_models_registry.py",
    "validate:templates": "python scripts/validate/validate_templates.py",
    "validate:manifests": "python scripts/validate/validate_manifests.py",
    "validate:comfyui-nodes": "python3 scripts/comfyui_node_compat/check.py",
    "build:all": "NX_ADD_PLUGINS=false NX_DAEMON=false npx nx run-many --target build --skip-nx-cache",
    "site:install": "cd site && pnpm install",
    "site:dev": "cd site && pnpm run dev",
    "site:sync": "cd site && pnpm run sync",
    "site:build": "cd site && SKIP_AI_GENERATION=true pnpm run build",
    "site:preview": "cd site && pnpm run preview"
  }
}
